{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "avoid",
  "bracketSpacing": true,
  "ignorePatterns": ["node_modules", "dist", "build", "*.tsbuildinfo"],
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "sortImports": true,
  "tabWidth": 2,
  "trailingComma": "es5"
}
