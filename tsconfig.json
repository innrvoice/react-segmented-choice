{
  "include": ["src", ".storybook"],
  "exclude": ["**/node_modules", "**/lib", "**/storybook-static"],
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "lib",
    "rootDir": ".",
    "lib": ["dom", "esnext"],
    "jsx": "react",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "pretty": true,
    "removeComments": true,
    "sourceMap": true,
    "strict": true,
    "strictNullChecks": true,
    "stripInternal": true,
    "target": "ES2020",
    "types": ["node"]
  }
}
